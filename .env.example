# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ========== GROQ AI API ==========
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ========== AZURE SPEECH SERVICES (Optional) ==========
# For voice support - Get from Azure Portal
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# ========== SERVER CONFIGURATION ==========
NODE_ENV=development
PORT=3000
HOST=localhost

# ========== DATABASE ==========
# Database connection string (optional)
DATABASE_URL=

# ========== LOGGING ==========
LOG_LEVEL=info
LOG_FILE=log.json

# ========== CORS SETTINGS ==========
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ========== SENSOR CONFIGURATION ==========
# Update these based on your hardware setup
SENSOR_READ_INTERVAL=30000
SERVER_SEND_INTERVAL=60000
RECEIVER_ESP_IP=192.168.1.100
RECEIVER_PORT=8080

# ========== WEATHER API (Optional) ==========
WEATHER_API_KEY=

# ========== FEATURES ==========
ENABLE_VOICE_SUPPORT=false
ENABLE_NOTIFICATIONS=true
ENABLE_HISTORICAL_ANALYSIS=true
